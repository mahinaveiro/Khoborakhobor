<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add newspaper"
        android:textColor="@color/khobor_text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/inputName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Newspaper name"
        android:inputType="textCapWords"
        android:maxLines="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/bg_input_field"
        android:textColor="@color/khobor_text"
        android:textColorHint="@color/khobor_text_muted"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/inputLink"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Website link"
        android:inputType="textUri"
        android:maxLines="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/bg_input_field"
        android:textColor="@color/khobor_text"
        android:textColorHint="@color/khobor_text_muted"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textColor="@color/khobor_text_muted"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/categorySpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_field"
        android:layout_marginBottom="20dp" />

</LinearLayout>
