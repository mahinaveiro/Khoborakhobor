<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homeHeaderRoot"
    android:layout_width="match_parent"
    android:layout_height="104dp"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/homeHeaderTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="BD + world newspapers"
        android:textColor="@color/khobor_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/homeTotalSources"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/khobor_text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/homeCategoryCount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/khobor_text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/homeBlockingState"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/khobor_text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
