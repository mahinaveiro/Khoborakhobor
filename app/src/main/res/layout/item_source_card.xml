<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sourceCardRoot"
    android:layout_width="match_parent"
    android:layout_height="168dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="11dp">

    <FrameLayout
        android:layout_width="42dp"
        android:layout_height="40dp">

        <TextView
            android:id="@+id/sourceInitials"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/khobor_text_muted"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/sourceIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="center"
            android:contentDescription="Source icon"
            android:scaleType="fitCenter"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/sourceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/khobor_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/sourceMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/khobor_text_muted"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/favoriteButton"
            android:layout_width="78dp"
            android:layout_height="34dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:textColor="@color/khobor_text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/deleteButton"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete custom source"
            android:padding="6dp"
            android:src="@drawable/ic_khobor_delete_24"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
