{
  "manifest_version": 2,
  "name": "Khoborakhobor Web Dark Overlay",
  "version": "1.0.4",
  "browser_specific_settings": {
    "gecko": {
      "id": "khobor-web-dark@khoborakhobor.local"
    }
  },
  "permissions": [
    "geckoViewAddons",
    "storage",
    "nativeMessaging",
    "nativeMessagingFromContent"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
